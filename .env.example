# Optional helper settings. Do not put real secrets in git.

# Expected xurl OAuth2 username shown by `xurl auth status`.
XTK_EXPECTED_X_USERNAME=your_x_username

# Optional xurl app name to use for OAuth2-only bookmark endpoints.
# Set this if your OAuth2 client registration lives under a non-default xurl app.
XTK_BOOKMARK_APP=default

# Public tweet used for exact-read smoke tests.
XTK_TEST_TWEET_URL=https://x.com/nousresearch/status/2056872329561710766

# Query used for xurl search smoke tests.
XTK_SEARCH_QUERY=OpenClaw

# Optional: skip live xurl read/search/bookmark checks when X API credits are depleted
# or when you only want to validate OpenClaw/xAI auth-profile search readiness.
XTK_SKIP_XURL_LIVE=0

# Optional 1Password reference for a direct X/Twitter bearer token.
# If unset, the doctor skips the legacy direct bearer lane.
XTK_BEARER_OP_REF=op://Vault/Item/Bearer Token

# Optional OpenClaw config/env paths.
XTK_OPENCLAW_CONFIG=$HOME/.openclaw/openclaw.json
XTK_OPENCLAW_ENV=$HOME/.openclaw/.env

# Optional xAI/Grok OAuth smoke settings. The doctor prefers OpenClaw auth profiles;
# XAI_API_KEY is only a fallback.
XTK_XAI_MODEL=xai/grok-4.3

# Optional xAI API-key fallback. If XAI_API_KEY is already in your environment or
# OpenClaw env file, the doctor reports it as fallback auth, not the primary lane.
# XAI_API_KEY=xai-...
