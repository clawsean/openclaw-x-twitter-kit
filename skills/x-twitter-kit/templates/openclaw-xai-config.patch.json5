// Example only. Prefer OpenClaw config schema/docs for your exact version.
// Do not commit real API keys.
{
  tools: {
    alsoAllow: ["x_search"],
  },
  plugins: {
    allow: ["xai"],
    entries: {
      xai: {
        enabled: true,
        config: {
          webSearch: {
            // Use a secret provider or env var, not plaintext.
            // apiKey: { source: "exec", provider: "onepassword_xai", id: "value" },
            baseUrl: "https://api.x.ai/v1",
          },
          xSearch: {
            enabled: true,
            baseUrl: "https://api.x.ai/v1",
            inlineCitations: false,
            maxTurns: 2,
            timeoutSeconds: 45,
            cacheTtlMinutes: 15,
          },
        },
      },
    },
  },
}
